<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/underwater_bg">

    <!-- Back Button -->
    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_margin="16dp"
        android:background="@drawable/bubble_bg"
        android:src="@android:drawable/ic_menu_revert"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white"
        android:contentDescription="Back Button" />

    <!-- Main Card -->
    <LinearLayout
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:background="@drawable/card_bg"
        android:backgroundTint="@color/white"
        android:orientation="vertical"
        android:padding="18dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Logo Placeholder -->
        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_gravity="center"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="Study Raid Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Signup Form"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp"/>

        <!-- Switch Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/login_signup_switch_bg"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp"
            android:padding="5dp">

            <TextView
                android:id="@+id/tv_go_to_login"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Login"
                android:gravity="center"
                android:textColor="@color/black"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/switch_signup"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Signup"
                android:gravity="center"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:background="@drawable/nav_bg"
                android:backgroundTint="@color/ocean_blue" />
        </LinearLayout>

        <EditText
            android:id="@+id/useruse"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:hint="Email Address"
            android:padding="7dp"
            android:background="@drawable/edit_text_bg"
            android:textColor="@color/black"
            android:textColorHint="#99000000"
            android:layout_marginBottom="5dp"
            android:inputType="textEmailAddress" />

        <EditText
            android:id="@+id/userpass"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:hint="Password"
            android:inputType="textPassword"
            android:padding="7dp"
            android:background="@drawable/edit_text_bg"
            android:textColor="@color/black"
            android:textColorHint="#99000000"
            android:layout_marginBottom="5dp" />

        <EditText
            android:id="@+id/userconfirm"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:hint="Confirm password"
            android:inputType="textPassword"
            android:padding="7dp"
            android:background="@drawable/edit_text_bg"
            android:textColor="@color/black"
            android:textColorHint="#99000000"
            android:layout_marginBottom="5dp" />

        <Button
            android:id="@+id/btn_signup_submit"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Signup"
            android:backgroundTint="@color/ocean_blue"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="15sp" />

    </LinearLayout>

    <!-- Bubbles -->
    <View android:id="@+id/bubble1" android:layout_width="20dp" android:layout_height="20dp" android:background="@drawable/bubble_bg" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" android:layout_marginStart="40dp" />
    <View android:id="@+id/bubble2" android:layout_width="30dp" android:layout_height="30dp" android:background="@drawable/bubble_bg" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" android:layout_marginEnd="40dp" />
    <ImageView android:id="@+id/fish1" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_fish" app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toEndOf="parent" android:layout_marginTop="60dp" android:contentDescription="Fish" />

</androidx.constraintlayout.widget.ConstraintLayout>
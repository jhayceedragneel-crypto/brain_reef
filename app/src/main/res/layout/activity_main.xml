<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/underwater_bg">

    <!-- Animated Bubbles -->
    <View
        android:id="@+id/bubble1"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:background="@drawable/bubble_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="50dp" />

    <View
        android:id="@+id/bubble2"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/bubble_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="150dp" />

    <View
        android:id="@+id/bubble3"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bubble_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="100dp" />

    <!-- Animated Fish -->
    <ImageView
        android:id="@+id/fish1"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_fish"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="100dp"
        android:contentDescription="Swimming Fish" />

    <ImageView
        android:id="@+id/fish2"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/ic_fish"
        android:tint="@color/seafoam"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="150dp"
        android:contentDescription="Swimming Fish" />

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/logo"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="Study Raid Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STUDY\nRAID"
            android:textColor="@color/accent_yellow"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/nav_bg"
            android:backgroundTint="@color/ocean_blue"
            android:paddingHorizontal="24dp"
            android:paddingVertical="8dp">

            <TextView
                android:id="@+id/nav_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="@color/seafoam"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginEnd="20dp" />

            <TextView
                android:id="@+id/nav_feature"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Feature"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginEnd="20dp" />

            <TextView
                android:id="@+id/nav_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Login"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="18sp" />
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/btn_start_learning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dive In"
            android:textColor="@color/accent_yellow"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bubble_bg"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="32dp"
        android:background="@drawable/card_bg"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Dive into the Abyss of\nKnowledge!"
            android:textColor="@color/white"
            android:textSize="48sp"
            android:textStyle="bold"
            android:gravity="center"
            android:fontFamily="cursive" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/underwater_bg">

    <!-- Sidebar -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="160dp"
        android:layout_height="0dp"
        android:background="@drawable/sidebar_bg"
        android:backgroundTint="@color/sidebar_bg"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Study Raid"
            android:textColor="@color/accent_yellow"
            android:textSize="20sp"
            android:textStyle="bold|italic"
            android:layout_marginBottom="32dp" />

        <TextView
            android:id="@+id/nav_home"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textColor="@color/seafoam"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/nav_quests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quests"
            android:textColor="@color/seafoam"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/nav_library"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Library"
            android:textColor="@color/seafoam"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/nav_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="@color/seafoam"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:gravity="center" />

    </LinearLayout>

    <!-- Animated Bubbles -->
    <View
        android:id="@+id/bubble1"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:background="@drawable/bubble_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        android:layout_marginStart="50dp" />

    <View
        android:id="@+id/bubble2"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/bubble_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="100dp" />

    <!-- Animated Fish -->
    <ImageView
        android:id="@+id/fish1"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:src="@drawable/ic_fish"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        android:layout_marginTop="80dp"
        android:contentDescription="Swimming Fish" />

    <!-- Content Area -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="@drawable/card_bg"
        android:layout_margin="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="File Attachment"
            android:textColor="@color/accent_yellow"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@android:drawable/ic_menu_save"
            android:background="@drawable/bubble_bg"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:contentDescription="Save Icon"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Secure your discovery in the\ndeep sea storage."
            android:textColor="@color/white"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btn_attach_file"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:text="Attach Discovery"
            android:backgroundTint="@color/button_quest"
            android:textColor="@color/white"
            android:padding="12dp"
            android:textStyle="bold"
            android:textAllCaps="false" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
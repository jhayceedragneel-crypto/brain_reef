<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/underwater_bg">

    <!-- Animated Bubbles -->
    <View
        android:id="@+id/bubble1"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:background="@drawable/bubble_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        android:layout_marginStart="30dp" />

    <View
        android:id="@+id/bubble2"
        android:layout_width="15dp"
        android:layout_height="15dp"
        android:background="@drawable/bubble_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="40dp" />

    <!-- Animated Fish -->
    <ImageView
        android:id="@+id/fish1"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:src="@drawable/ic_fish"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        android:layout_marginTop="100dp"
        android:contentDescription="Swimming Fish" />

    <!-- Sidebar -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="160dp"
        android:layout_height="0dp"
        android:background="@drawable/sidebar_bg"
        android:backgroundTint="@color/sidebar_bg"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Study Raid"
            android:textColor="@color/accent_yellow"
            android:textSize="20sp"
            android:textStyle="bold|italic"
            android:layout_marginBottom="32dp" />

        <TextView
            android:id="@+id/nav_home"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textColor="@color/seafoam"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/nav_quests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quests"
            android:textColor="@color/seafoam"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/nav_library"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Library"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:background="@drawable/nav_bg"
            android:backgroundTint="@color/ocean_blue"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/nav_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="@color/seafoam"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:gravity="center" />

    </LinearLayout>

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Treasures Collected"
        android:textColor="@color/white"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
        android:scrollbarTrackVertical="@drawable/scrollbar_track"
        android:scrollbars="vertical"
        android:fadeScrollbars="false"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintEnd_toEndOf="parent">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:padding="16dp"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false">

            <!-- Duplicated items for vertical scroll -->
            <LinearLayout
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_margin="12dp">
                <ImageView android:layout_width="match_parent" android:layout_height="90dp" android:background="@drawable/nav_bg" android:backgroundTint="@color/bubble_blue" android:src="@android:drawable/ic_menu_gallery" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Math" android:textColor="@color/accent_yellow" android:textStyle="bold" android:textSize="18sp" android:gravity="center" android:layout_marginTop="12dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="150dp" android:layout_height="wrap_content" android:background="@drawable/card_bg" android:orientation="vertical" android:padding="16dp" android:layout_margin="12dp">
                <ImageView android:layout_width="match_parent" android:layout_height="90dp" android:background="@drawable/nav_bg" android:backgroundTint="@color/bubble_blue" android:src="@android:drawable/ic_menu_gallery" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Science" android:textColor="@color/accent_yellow" android:textStyle="bold" android:textSize="18sp" android:gravity="center" android:layout_marginTop="12dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="150dp" android:layout_height="wrap_content" android:background="@drawable/card_bg" android:orientation="vertical" android:padding="16dp" android:layout_margin="12dp">
                <ImageView android:layout_width="match_parent" android:layout_height="90dp" android:background="@drawable/nav_bg" android:backgroundTint="@color/bubble_blue" android:src="@android:drawable/ic_menu_gallery" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="English" android:textColor="@color/accent_yellow" android:textStyle="bold" android:textSize="18sp" android:gravity="center" android:layout_marginTop="12dp" />
            </LinearLayout>
            <!-- Row 2 -->
            <LinearLayout android:layout_width="150dp" android:layout_height="wrap_content" android:background="@drawable/card_bg" android:orientation="vertical" android:padding="16dp" android:layout_margin="12dp">
                <ImageView android:layout_width="match_parent" android:layout_height="90dp" android:background="@drawable/nav_bg" android:backgroundTint="@color/bubble_blue" android:src="@android:drawable/ic_menu_gallery" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="History" android:textColor="@color/accent_yellow" android:textStyle="bold" android:textSize="18sp" android:gravity="center" android:layout_marginTop="12dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="150dp" android:layout_height="wrap_content" android:background="@drawable/card_bg" android:orientation="vertical" android:padding="16dp" android:layout_margin="12dp">
                <ImageView android:layout_width="match_parent" android:layout_height="90dp" android:background="@drawable/nav_bg" android:backgroundTint="@color/bubble_blue" android:src="@android:drawable/ic_menu_gallery" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Art" android:textColor="@color/accent_yellow" android:textStyle="bold" android:textSize="18sp" android:gravity="center" android:layout_marginTop="12dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="150dp" android:layout_height="wrap_content" android:background="@drawable/card_bg" android:orientation="vertical" android:padding="16dp" android:layout_margin="12dp">
                <ImageView android:layout_width="match_parent" android:layout_height="90dp" android:background="@drawable/nav_bg" android:backgroundTint="@color/bubble_blue" android:src="@android:drawable/ic_menu_gallery" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Music" android:textColor="@color/accent_yellow" android:textStyle="bold" android:textSize="18sp" android:gravity="center" android:layout_marginTop="12dp" />
            </LinearLayout>
             <!-- Row 3 -->
            <LinearLayout android:layout_width="150dp" android:layout_height="wrap_content" android:background="@drawable/card_bg" android:orientation="vertical" android:padding="16dp" android:layout_margin="12dp">
                <ImageView android:layout_width="match_parent" android:layout_height="90dp" android:background="@drawable/nav_bg" android:backgroundTint="@color/bubble_blue" android:src="@android:drawable/ic_menu_gallery" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Geography" android:textColor="@color/accent_yellow" android:textStyle="bold" android:textSize="18sp" android:gravity="center" android:layout_marginTop="12dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="150dp" android:layout_height="wrap_content" android:background="@drawable/card_bg" android:orientation="vertical" android:padding="16dp" android:layout_margin="12dp">
                <ImageView android:layout_width="match_parent" android:layout_height="90dp" android:background="@drawable/nav_bg" android:backgroundTint="@color/bubble_blue" android:src="@android:drawable/ic_menu_gallery" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Physics" android:textColor="@color/accent_yellow" android:textStyle="bold" android:textSize="18sp" android:gravity="center" android:layout_marginTop="12dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="150dp" android:layout_height="wrap_content" android:background="@drawable/card_bg" android:orientation="vertical" android:padding="16dp" android:layout_margin="12dp">
                <ImageView android:layout_width="match_parent" android:layout_height="90dp" android:background="@drawable/nav_bg" android:backgroundTint="@color/bubble_blue" android:src="@android:drawable/ic_menu_gallery" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Biology" android:textColor="@color/accent_yellow" android:textStyle="bold" android:textSize="18sp" android:gravity="center" android:layout_marginTop="12dp" />
            </LinearLayout>

        </GridLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
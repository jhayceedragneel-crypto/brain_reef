<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/underwater_bg">

    <!-- Sidebar -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="160dp"
        android:layout_height="0dp"
        android:background="@drawable/sidebar_bg"
        android:backgroundTint="@color/sidebar_bg"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/study_raid"
            android:textColor="@color/accent_yellow"
            android:textSize="20sp"
            android:textStyle="bold|italic"
            android:layout_marginBottom="32dp" />

        <TextView
            android:id="@+id/nav_home"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/home"
            android:textColor="@color/seafoam"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/nav_quests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/quests"
            android:textColor="@color/seafoam"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/nav_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:background="@drawable/nav_bg"
            android:backgroundTint="@color/ocean_blue"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/nav_library"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/library"
            android:textColor="@color/seafoam"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/nav_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings"
            android:textColor="@color/seafoam"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:gravity="center" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Explorer Profile"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Profile Info Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/card_bg"
                android:backgroundTint="@color/white"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginEnd="16dp">

                <TextView
                    android:id="@+id/tv_current_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Name: Explorer"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <EditText
                    android:id="@+id/et_new_username"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter New Username"
                    android:padding="12dp"
                    android:background="@drawable/edit_text_bg"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btn_update_username"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Update Name"
                    android:backgroundTint="@color/ocean_blue"
                    android:textColor="@color/white" />

            </LinearLayout>

            <!-- Activity History Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="300dp"
                android:layout_weight="1.5"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Deep Sea Log (History)"
                    android:textColor="@color/accent_yellow"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
                    android:scrollbarTrackVertical="@drawable/scrollbar_track"
                    android:scrollbars="vertical"
                    android:fadeScrollbars="false">

                    <TextView
                        android:id="@+id/tv_activity_history"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No logs yet..."
                        android:textColor="@color/white"
                        android:textSize="14sp" />
                </ScrollView>

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Bubbles and Fish -->
    <View android:id="@+id/bubble1" android:layout_width="20dp" android:layout_height="20dp" android:background="@drawable/bubble_bg" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toEndOf="@id/sidebar" android:layout_marginStart="40dp" />
    <ImageView android:id="@+id/fish1" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_fish" app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toEndOf="parent" android:layout_marginTop="60dp" android:contentDescription="Fish" />

</androidx.constraintlayout.widget.ConstraintLayout>